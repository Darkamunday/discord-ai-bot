# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret
DISCORD_REDIRECT_URI=http://127.0.0.1:5000/callback

# Flask admin UI
FLASK_SECRET_KEY=change_this_to_a_random_string

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# ComfyUI (remote)
COMFYUI_BASE_URL=http://your_comfyui_ip:8188

# Web app — which guild's config to use (0 = defaults)
WEBAPP_GUILD_ID=0

# Owner-only commands (your Discord user ID — enable dev mode in Discord to copy it)
BOT_OWNER_ID=your_discord_user_id_here
